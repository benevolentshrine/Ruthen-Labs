#!/bin/bash
set -e

case "$1" in
    remove)
        # Clean up runtime directories (but preserve user data)
        rm -rf /tmp/momo/boru.sock 2>/dev/null || true
        ;;
    purge)
        # Full cleanup including logs and database
        rm -rf /tmp/momo 2>/dev/null || true
        rm -rf /var/log/boru 2>/dev/null || true
        rm -rf /var/lib/boru 2>/dev/null || true
        ;;
esac

exit 0
